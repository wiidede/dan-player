{
  "name": "@wiidede/dan-player",
  "type": "module",
  "version": "0.3.0",
  "packageManager": "pnpm@10.12.4",
  "description": "Dan Player is a bullet screen player component developed based on Vue, supporting MKV format, and supporting ASS, SRT subtitles.Dan Player 是一个基于 Vue 开发的弹幕播放器组件，支持MKV格式，支持ASS、SRT字幕",
  "author": "wiidede <wiixdede@gmail.com>",
  "license": "MIT",
  "funding": "https://wiidede.space/sponsor",
  "homepage": "https://github.com/wiidede/dan-player#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wiidede/dan-player.git"
  },
  "bugs": "https://github.com/wiidede/dan-player/issues",
  "keywords": [
    "danmaku",
    "bullet screen",
    "player",
    "video",
    "mkv",
    "ass",
    "srt",
    "弹幕"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./index.css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite playground --mode play",
    "dev:pkg": "vite playground",
    "preview": "vite preview playground",
    "build:play": "vite build && vite build playground",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "pnpm lint && pnpm typecheck && pnpm build && bumpp",
    "start": "esno src/index.ts",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@vueuse/core": "^13.5.0",
    "@vueuse/math": "^13.5.0",
    "@wiidede/comment-core-library": "^0.2.0",
    "@wiidede/ebml": "^0.1.1",
    "assjs": "^0.1.4",
    "element-plus": "^2.10.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.2",
    "@antfu/ni": "^25.0.0",
    "@antfu/utils": "^9.2.0",
    "@iconify-json/carbon": "^1.2.10",
    "@iconify/utils": "^2.3.0",
    "@types/ebml": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.10",
    "@unocss/eslint-config": "^66.3.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^10.2.0",
    "defu": "^6.1.4",
    "eslint": "^9.30.1",
    "eslint-plugin-format": "^1.0.1",
    "esno": "^4.8.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "pnpm": "^10.12.4",
    "rimraf": "^6.0.1",
    "rollup": "^4.44.1",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "unocss": "^66.3.2",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-dts": "1.0.0-beta.2",
    "unplugin-vue-components": "^28.8.0",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-inspect": "^11.3.0",
    "vite-plugin-static-copy": "^3.1.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.17",
    "vue-tsc": "^3.0.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
