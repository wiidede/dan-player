{
  "name": "@wiidede/dan-player",
  "type": "module",
  "version": "0.4.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Dan Player is a bullet screen player component developed based on Vue, supporting MKV format, and supporting ASS, SRT subtitles.Dan Player 是一个基于 Vue 开发的弹幕播放器组件，支持MKV格式，支持ASS、SRT字幕",
  "author": "wiidede <wiixdede@gmail.com>",
  "license": "MIT",
  "funding": "https://wiidede.space/sponsor",
  "homepage": "https://github.com/wiidede/dan-player#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wiidede/dan-player.git"
  },
  "bugs": "https://github.com/wiidede/dan-player/issues",
  "keywords": [
    "danmaku",
    "bullet screen",
    "player",
    "video",
    "mkv",
    "ass",
    "srt",
    "弹幕"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./index.css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite playground --mode play",
    "dev:pkg": "vite playground",
    "preview": "vite preview playground",
    "build:play": "vite build && vite build playground",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "pnpm lint && pnpm typecheck && pnpm build && bumpp",
    "start": "esno src/index.ts",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "@vueuse/math": "^14.2.1",
    "@wiidede/comment-core-library": "^0.2.0",
    "@wiidede/ebml": "^0.1.1",
    "assjs": "^0.1.6",
    "element-plus": "^2.13.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@antfu/ni": "^30.1.0",
    "@antfu/utils": "^9.3.0",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify/utils": "^3.1.1",
    "@types/ebml": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@unocss/eslint-config": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.9",
    "bumpp": "^11.0.1",
    "defu": "^6.1.7",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "esno": "^4.8.0",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "pnpm": "^10.33.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-dts": "1.0.0-beta.6",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
